---
import SiteChrome from "./SiteChrome.astro";

type Entry = {
    data: {
        title: string;
        description?: string;
    };
};

type NavGroup = {
    title: string;
    links: Array<{
        label: string;
        href: string;
    }>;
};

const { entry } = Astro.props as { entry: Entry };
const base = import.meta.env.BASE_URL;
const href = (path: string) => `${base}${path}`;

const overviewNav: NavGroup[] = [
    {
        title: "Run",
        links: [
            { label: "Quick Start", href: "#quick-start" },
            { label: "Quick Deploy", href: "#quick-deploy" },
            { label: "Connection resilience", href: "#connection-resilience" },
            { label: "Configuration", href: "#configuration" },
            { label: "Commands", href: "#commands" },
            {
                label: "Membership and channels",
                href: "#membership-and-channels",
            },
            { label: "Development", href: "#development" },
        ],
    },
    {
        title: "Operate",
        links: [
            { label: "Notifications", href: "#notifications" },
            {
                label: "Backup & systemd",
                href: "#backup-export-and-daemons",
            },
        ],
    },
];

const sectionNav = overviewNav;
---

<SiteChrome
    title={`${entry.data.title} | sshoosh`}
    description={entry.data.description ?? "sshoosh documentation"}
    current="docs"
>
    <div class="docs-layout">
        <aside class="sidebar" aria-label="Documentation navigation">
            <a class="sidebar-title" href={href("docs/")}>
                <span>sshoosh docs</span>
            </a>
            <section class="nav-section">
                <h2>Start</h2>
                <a href={href("docs/")} aria-current="page">Overview</a>
                <a href={href("manual/")}>User Manual</a>
            </section>
            {
                sectionNav.map((group) => (
                    <section class="nav-section">
                        <h2>{group.title}</h2>
                        {group.links.map((link) => (
                            <a href={link.href}>{link.label}</a>
                        ))}
                    </section>
                ))
            }
        </aside>

        <main class="doc-main">
            <p class="doc-kicker"><span class="prompt">$</span> man sshoosh</p>
            <h1>{entry.data.title}</h1>
            {
                entry.data.description && (
                    <p class="doc-description">{entry.data.description}</p>
                )
            }
            <article class="doc-article">
                <slot />
            </article>
        </main>
    </div>
</SiteChrome>
