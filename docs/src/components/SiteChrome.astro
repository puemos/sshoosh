---
import '../styles/site.css';

const {
  title = 'sshoosh',
  description = 'A self-hosted SSH/TUI workspace chat.',
  current = 'home',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const href = (path: string) => `${base}${path}`;
const githubUrl = 'https://github.com/puemos/sshoosh';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('sshoosh-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.dataset.theme = stored || (prefersDark ? 'dark' : 'light');
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={href('favicon.svg')} />
  </head>
  <body>
    <div class="site-frame">
      <header class="topline">
        <a class="brand" href={href('')} aria-label="sshoosh">
          <img
            class="brand-logo brand-logo-light"
            src={href('assets/sshoosh-logo-light.svg')}
            alt=""
            aria-hidden="true"
          />
          <img
            class="brand-logo brand-logo-dark"
            src={href('assets/sshoosh-logo.svg')}
            alt=""
            aria-hidden="true"
          />
        </a>
        <nav aria-label="Primary navigation">
          <a href={href('')} aria-current={current === 'home' ? 'page' : undefined}>home</a>
          <a href={href('docs/')} aria-current={current === 'docs' ? 'page' : undefined}>docs</a>
          <a href={href('manual/')} aria-current={current === 'manual' ? 'page' : undefined}>manual</a>
          <button class="theme-toggle" type="button" data-theme-toggle>theme</button>
        </nav>
      </header>
      <slot />
      <footer class="bottombar">
        <a href={githubUrl}>github</a>
        <span>created by Shy Alter</span>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const button = document.querySelector('[data-theme-toggle]');
        if (!button) return;

        const sync = () => {
          const theme = document.documentElement.dataset.theme || 'light';
          button.textContent = theme === 'dark' ? 'light' : 'dark';
          button.setAttribute('aria-label', `Switch to ${button.textContent} mode`);
        };

        button.addEventListener('click', () => {
          const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          localStorage.setItem('sshoosh-theme', next);
          sync();
        });

        sync();
      })();
    </script>
  </body>
</html>
