---
import { Code } from 'astro:components';
import SiteChrome from '../components/SiteChrome.astro';

const base = import.meta.env.BASE_URL;
const href = (path: string) => `${base}${path}`;
const startCommand = `# Install via the release script
curl -fsSL https://raw.githubusercontent.com/puemos/sshoosh/main/install.sh | sh

# Or install with Homebrew
brew install puemos/tap/sshoosh

sshoosh bootstrap-token
sshoosh serve --host 0.0.0.0 --port 2222
ssh -p 2222 127.0.0.1
# Paste the bootstrap token at the "Token:" prompt,
# then choose your username in the TUI.`;
const codeThemes = {
  light: 'github-light',
  dark: 'github-dark',
};
---

<SiteChrome
  title="sshoosh"
  description="A self-hosted SSH/TUI workspace chat for thread-first teams."
  current="home"
>
  <main class="landing">
    <p class="eyebrow">sshoosh(1)</p>
    <h1>SSH workspace chat, served as a terminal.</h1>
    <p class="lede">
      `sshoosh` is a self-hosted chat server where users connect with SSH keys
      and work inside a dense TUI. It keeps the deployment small: one binary,
      one SQLite database, one SSH host key.
    </p>

    <section class="block">
      <h2>Demo</h2>
      <video
        class="demo-video"
        controls
        muted
        playsinline
        preload="metadata"
        poster={href('assets/demo-poster.jpg')}
        width="1280"
        height="720"
      >
        <source src={href('assets/demo.webm')} type="video/webm" />
        <source src={href('assets/demo.mp4')} type="video/mp4" />
        <a href={href('assets/demo.mp4')}>watch the demo</a>
      </video>
    </section>

    <section class="block">
      <h2>Start</h2>
      <Code
        code={startCommand}
        lang="sh"
        themes={codeThemes}
        defaultColor={false}
        class="command-card"
      />
      <div class="actions">
        <a class="button" href={href('docs/')}>read docs</a>
        <a class="button secondary" href={href('docs/#quick-start')}>quick start</a>
      </div>
    </section>
  </main>
</SiteChrome>
